# ──────────────────────────────────────────────────────────────────────────────
# AFP Simulator — Variables de entorno
# Copia este archivo como frontend/.env.local y edita los valores.
# Para Vercel: agrégalas en el dashboard (Settings → Environment Variables).
# ──────────────────────────────────────────────────────────────────────────────

# Banco Central de Chile — UTM, IPC (si3.bcentral.cl → activar acceso web)
# Sin estas credenciales el simulador usa valores de respaldo actualizados
BCCH_USER=
BCCH_PASS=

# Supabase (para persistencia de simulaciones, opcional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# NO se necesita NEXT_PUBLIC_FASTAPI_URL — el backend corre dentro de Next.js
# ──────────────────────────────────────────────────────────────────────────────
