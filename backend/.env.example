# Database — Use environment variable in production, NEVER hardcode in .ini
DATABASE_URL=postgresql://user:password@localhost:5432/simulador_afp

# Banco Central de Chile (BCCH) API
BCCH_USER=your_bcch_user
BCCH_PASS=your_bcch_password

# AFP Commission API
QUETALMIAFP_API_KEY=your_api_key

# Supabase (if using)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# CORS Origins (comma-separated for production)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
