# ──────────────────────────────────────────────────────────────────────────────
# AFP Simulator — Variables de entorno
# Copia este archivo como .env en la carpeta backend/ y edita los valores.
# Todas las variables son OPCIONALES para uso básico local.
# ──────────────────────────────────────────────────────────────────────────────

# API externa para comisiones actualizadas (queafp.cl)
# Sin esta clave se usan los datos hardcodeados como fallback
QUETALMIAFP_API_KEY=

# Banco Central de Chile — UTM, IPC (si3.bcentral.cl → activar acceso web en tu perfil)
# Sin estas credenciales el simulador usa valores de respaldo actualizados
BCCH_USER=
BCCH_PASS=

# Supabase (para persistencia de simulaciones, opcional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=

# Base de datos (SQLite por defecto para desarrollo, PostgreSQL en producción)
DATABASE_URL=sqlite:///./afp_dev.db
# DATABASE_URL=postgresql://user:password@localhost:5432/afp_simulator

# CORS — lista separada por comas de orígenes permitidos
ALLOWED_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# Frontend (archivo frontend/.env.local)
# ──────────────────────────────────────────────────────────────────────────────
# URL del backend FastAPI
NEXT_PUBLIC_FASTAPI_URL=http://localhost:8000
